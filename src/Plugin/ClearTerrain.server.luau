local ChangeHistoryService = game:GetService("ChangeHistoryService")
local toolbar = plugin:CreateToolbar("DemonBlade2")
local btn = toolbar:CreateButton("Clear Terrain", "Wipe all terrain in edit mode", "rbxassetid://7072706661")
btn.Click:Connect(function()
	btn:SetActive(false)
	ChangeHistoryService:SetWaypoint("Before Clear Terrain")
	workspace.Terrain:Clear()
	ChangeHistoryService:SetWaypoint("After Clear Terrain")
	print("[DemonBlade2] Terrain cleared.")
end)
